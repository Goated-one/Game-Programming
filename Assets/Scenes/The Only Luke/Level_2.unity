  m_Script: {fileID: 11500000, guid: 30cb3be4235ab1a418e6a5b433a487f8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::JournalManager
  daftarMusuh:
  - namaBakteri: Bakteri
    infoPenyakit: Bakteri ini biasanya datang dari kebiasaan anak-anak yang kurang
      bersih. Mereka bisa masuk kalau anak-anak lupa cuci tangan sebelum makan, suka
      jajan sembarangan, atau membiarkan luka yang jatuh kena tanah kotor tidak dibersihkan.
      Di dalam tubuh, bakteri suka berkumpul dan berkembang biak. Kalau kalian tidak
      segera mengusirnya, bakteri ini bisa menyebabkan penyakit seperti diare yang
      bikin perut melilit, tifus, atau membuat luka anak-anak jadi bengkak dan bernanah.
    fotoBakteri: {fileID: 5827293808285669160, guid: 57c3a519794f4c04d888eed759fd7731, type: 3}
    sudahKetemu: 0
    tombolUI: {fileID: 195695154}
  - namaBakteri: Virus
    infoPenyakit: Nah, kalau Virus ini musuh yang lebih nakal dan gesit. Mereka biasanya
      terbang di udara dan masuk saat anak-anak menghirup napas di dekat orang yang
      sedang batuk atau bersin, apalagi kalau tubuh anak-anak sedang lelah. Virus
      sangat jahat karena suka menyelinap dan bersembunyi di dalam sel tubuh yang
      sehat. Kalau kalian gagal menangkapnya, virus bisa menyebabkan penyakit seperti
      flu, batuk, dan demam tinggi yang membuat badan anak-anak terasa sangat panas,
      pusing, dan lemas sekali.
    fotoBakteri: {fileID: -1681170142669992842, guid: efcb6ff90d6bf2a4987c2f9c1634c08a, type: 3}
    sudahKetemu: 0
    tombolUI: {fileID: 1422375873}
  teksJudul: {fileID: 811069861}
  teksInfo: {fileID: 2053273527}
  komponenGambarUI: {fileID: 1528686845}
  journalPanel: {fileID: 1841900580}
